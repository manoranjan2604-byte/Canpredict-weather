# Copy this file to .env for local development.
# On Render, set these as Environment Variables in the service dashboard instead.

# WeatherAPI.com API key - https://www.weatherapi.com/my/
WEATHER_API_KEY=
# Google Gemini API key - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Gemini model name (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: comma-separated list of allowed CORS origins, or "*" for all
CORS_ORIGINS=*

# Optional: in-memory cache TTL in seconds (default 180 = 3 minutes)
CACHE_TTL_SECONDS=180

# Local dev server port (Render sets PORT automatically in production)
PORT=5000

# Optional: "true" to enable Flask debug mode locally
FLASK_DEBUG=false

# Optional: Python logging level
LOG_LEVEL=INFO
